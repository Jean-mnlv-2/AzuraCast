# BantuWave Backend Environment Variables (Exemple)

# --- Django Settings ---
DEBUG=True
SECRET_KEY=générer_une_cle_secrete_ici
ALLOWED_HOSTS=localhost,127.0.0.1,votre-domaine.com

# --- Database ---
DATABASE_URL=postgres://user:password@db:5432/dbname

# --- Redis & Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Object Storage (S3/MinIO) ---
USE_S3=False
AWS_ACCESS_KEY_ID=votre_access_key
AWS_SECRET_ACCESS_KEY=votre_secret_key
AWS_STORAGE_BUCKET_NAME=bantuwave-media
AWS_S3_ENDPOINT_URL=https://s3.votre-serveur.com
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=cdn.bantuwave.com
